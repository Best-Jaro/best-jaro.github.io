---
import Layout from '../layouts/Layout.astro';

const hero = {
  name: 'Best_Jaro',

  pixel: 'BEGINNER PYTHON · C++ · KOTLIN · TWITCH STREAMER'
};

const socials = [
  {
    label: 'github.com/best-jaro',
    href: 'https://github.com/best-jaro',
    icon: 'https://raw.githubusercontent.com/Best-Jaro/best-jaro.github.io/346847d1ba655dd1dcd9a04252b6aed5dc72a959/src/assets/Octicons-mark-github.svg'
  },
  {
    label: 'discord.best_jaro',
    href: 'https://discord.com/users/695567308126421003',
    icon: 'https://raw.githubusercontent.com/Best-Jaro/best-jaro.github.io/346847d1ba655dd1dcd9a04252b6aed5dc72a959/src/assets/discord-icon.svg'
  },
  {
    label: 'twitch.tv/best_jaro',
    href: 'https://twitch.tv/best_jaro',
    icon: 'https://raw.githubusercontent.com/Best-Jaro/best-jaro.github.io/346847d1ba655dd1dcd9a04252b6aed5dc72a959/src/assets/logo-twitch.svg'
  }
];
---

<Layout title="Best_Jaro — Главная">
  <main class="scene">
    <img
      class="scene__bg"
      src="https://raw.githubusercontent.com/Best-Jaro/best-jaro.github.io/refs/heads/master/src/assets/background.png"
      alt="Размытый темный градиент"
      aria-hidden="false"
    />
    <article class="hero-card" aria-label="Приветственная карточка Best Jaro">
      <div class="hero-card__top">
        <div class="hero-card__avatar-wrap">
          <img
            class="hero-card__avatar"
            src="https://raw.githubusercontent.com/Best-Jaro/best-jaro.github.io/refs/heads/master/src/assets/Best_Jaro_avatar.png"
            alt="Портрет аватара Best Jaro"
          />
          <span class="hero-card__caption">me btw</span>
        </div>
        <div>
          <p class="hero-card__tagline">HI,</p>
          <h1 class="hero-card__title">
            I&apos;m <span>{hero.name}</span>
          </h1>
          <p class="hero-card__tagline">{hero.tagline}</p>
          <p class="hero-card__pixel">{hero.pixel}</p>
        </div>
      </div>
      <div class="hero-divider" aria-hidden="true"></div>
      <div class="socials" role="list">
        {socials.map((item) => (
          <a class="social-card" href={item.href} target="_blank" rel="noreferrer" role="listitem">
            <img class="social-card__icon" src={item.icon} alt="" aria-hidden="true" />
            <span class="social-card__label">{item.label}</span>
          </a>
        ))}
      </div>
    </article>
  </main>
</Layout>
